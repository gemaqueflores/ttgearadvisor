{
  "expo": {
    "name": "Table Tennis Gear Advisor",
    "slug": "tt-gear-advisor",
    "version": "1.0.0",
    "scheme": "ttgearadvisor",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3ecdf"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.lfsystems.ttgearadvisor"
    },
    "android": {
      "package": "br.com.lfsystems.ttgearadvisor",
      "adaptiveIcon": {
        "backgroundColor": "#f3ecdf",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f058c65-b7cf-4978-9cc6-f0abf1d8a238"
      }
    },
    "owner": "lfsystems"
  }
}
